# Catalynx Environment Configuration
# Generated: 2025-11-17 04:00:29 

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-here-generate-with-python-secrets
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Admin Credentials (CHANGE THESE\!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# User Credentials (CHANGE THESE\!)
USER_USERNAME=user
USER_PASSWORD=change-me-user-password

# OpenAI API Configuration (legacy — used by existing GPT-5 processors)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Configuration (Claude — primary AI for screening pipeline)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude Model Routing (override defaults per pipeline stage)
# CLAUDE_MODEL_DISCOVERY=claude-haiku-4-5-20251001
# CLAUDE_MODEL_FAST_SCREENING=claude-haiku-4-5-20251001
# CLAUDE_MODEL_THOROUGH_SCREENING=claude-sonnet-4-6
# CLAUDE_MODEL_DEEP_INTELLIGENCE=claude-sonnet-4-6
# CLAUDE_MODEL_PREMIUM_INTELLIGENCE=claude-opus-4-6

# Database Configuration
DATABASE_PATH=data/catalynx.db
