CSP_SCRIPT_SRC=self
CSP_STYLE_SRC=self,https://cdn.tailwindcss.com

# Cache Configuration
CACHE_ENABLED=true
CACHE_MAX_SIZE_MB=500
CACHE_TTL_SECONDS=3600
